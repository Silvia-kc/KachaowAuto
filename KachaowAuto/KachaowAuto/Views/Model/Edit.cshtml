@model KachaowAuto.ViewModels.Model.ModelEditViewModel

@{
    ViewData["Title"] = "Edit Model";
}

<div class="admin-page">
    <div class="admin-header">
        <div class="admin-title-wrap">
            <h1>Edit Model</h1>
            <p class="admin-subtitle">
                Update model details, engine specifications and body type information.
            </p>
        </div>
    </div>

    <div class="admin-form-wrap">
        <div class="admin-form-card">
            <div class="admin-form-head">
                <h2 class="admin-form-title">Edit Model Details</h2>
                <p class="admin-form-subtitle">Make changes to the selected vehicle model.</p>
            </div>

            <div class="admin-form-body">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="ModelId" />
                    @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

                    <div class="mb-3">
                        <label asp-for="BrandId" class="form-label">Brand</label>
                        <select asp-for="BrandId" class="form-select"
                                asp-items="@(new SelectList(Model.Brands, "BrandId", "BrandName"))">
                            <option value="">-- Select brand --</option>
                        </select>
                        <span asp-validation-for="BrandId" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ModelName" class="form-label">Model Name</label>
                        <input asp-for="ModelName" class="form-control" placeholder="Enter model name" />
                        <span asp-validation-for="ModelName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="EngineTypeId" class="form-label">Engine Type</label>
                        <select asp-for="EngineTypeId" class="form-select"
                                asp-items="@(new SelectList(Model.EngineTypes, "EngineTypeId", "Name"))">
                            <option value="">-- Select engine type --</option>
                        </select>
                        <span asp-validation-for="EngineTypeId" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="EngineVolume" class="form-label">Engine Volume</label>
                        <input asp-for="EngineVolume" class="form-control" type="number" step="0.1" placeholder="Enter engine volume" />
                        <span asp-validation-for="EngineVolume" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="HorsePower" class="form-label">Horse Power</label>
                        <input asp-for="HorsePower" class="form-control" type="number" placeholder="Enter horse power" />
                        <span asp-validation-for="HorsePower" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="BodyTypeId" class="form-label">Body Type</label>
                        <select asp-for="BodyTypeId" class="form-select"
                                asp-items="@(new SelectList(Model.BodyTypes, "BodyTypeId", "Name"))">
                            <option value="">-- Select body type --</option>
                        </select>
                        <span asp-validation-for="BodyTypeId" class="text-danger"></span>
                    </div>

                    <div class="admin-form-actions">
                        <button type="submit" class="btn btn-primary btn-admin">Save Changes</button>
                        <a asp-action="Index" class="btn btn-secondary btn-admin">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}