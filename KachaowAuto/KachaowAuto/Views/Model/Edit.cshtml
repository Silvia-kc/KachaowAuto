@model KachaowAuto.ViewModels.Model.ModelEditViewModel

<h2>Edit Model</h2>

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="ModelId" />
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

    <div class="mb-3">
        <label asp-for="BrandId" class="form-label"></label>
        <select class="form-select" asp-for="BrandId"
                asp-items="@(new SelectList(Model.Brands, "BrandId", "BrandName"))">
            <option value="">-- select brand --</option>
        </select>
        <span asp-validation-for="BrandId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ModelName" class="form-label"></label>
        <input class="form-control" asp-for="ModelName" />
        <span asp-validation-for="ModelName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="EngineTypeId" class="form-label"></label>
        <select class="form-select" asp-for="EngineTypeId"
                asp-items="@(new SelectList(Model.EngineTypes, "EngineTypeId", "Name"))">
            <option value="">-- select engine type --</option>
        </select>
        <span asp-validation-for="EngineTypeId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="EngineVolume" class="form-label"></label>
        <input class="form-control" asp-for="EngineVolume" type="number" step="0.1" />
        <span asp-validation-for="EngineVolume" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="HorsePower" class="form-label"></label>
        <input class="form-control" asp-for="HorsePower" type="number" />
        <span asp-validation-for="HorsePower" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="BodyTypeId" class="form-label"></label>
        <select class="form-select" asp-for="BodyTypeId"
                asp-items="@(new SelectList(Model.BodyTypes, "BodyTypeId", "Name"))">
            <option value="">-- select body type --</option>
        </select>
        <span asp-validation-for="BodyTypeId" class="text-danger"></span>
    </div>

    <button class="btn btn-primary">Save</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}