@model IEnumerable<KachaowAuto.ViewModels.Model.ModelListViewModel>

@{
    ViewData["Title"] = "Models";
}

<div class="admin-page">
    <div class="admin-header">
        <div class="admin-title-wrap">
            <h1>Models</h1>
            <p class="admin-subtitle">
                Manage vehicle models, engine types, power and body configurations in the system.
            </p>
        </div>

        <div class="admin-toolbar">
            <a asp-action="Create" class="btn btn-primary btn-admin">Create Model</a>
        </div>
    </div>

    <div class="admin-stats">
        <div class="admin-stat-card">
            <div class="admin-stat-label">Total Models</div>
            <div class="admin-stat-value accent">@Model.Count()</div>
        </div>

        <div class="admin-stat-card">
            <div class="admin-stat-label">Catalog Section</div>
            <div class="admin-stat-value">Models</div>
        </div>

        <div class="admin-stat-card">
            <div class="admin-stat-label">Management Area</div>
            <div class="admin-stat-value">Admin</div>
        </div>
    </div>

    <div class="admin-panel">
        <div class="admin-panel-head">
            <div>
                <h2 class="admin-panel-title">Model Directory</h2>
                <p class="admin-panel-text">Browse, edit and maintain all registered vehicle models.</p>
            </div>
        </div>

        <div class="admin-table-wrap">
            <table class="table admin-table">
                <thead>
                    <tr>
                        <th>Brand</th>
                        <th>Model</th>
                        <th>Engine Type</th>
                        <th>Volume</th>
                        <th>HP</th>
                        <th>Body Type</th>
                        <th style="width: 220px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in Model)
                    {
                        <tr>
                            <td>@m.BrandName</td>
                            <td>@m.ModelName</td>
                            <td>@m.EngineTypeName</td>
                            <td>@m.EngineVolume</td>
                            <td>@m.HorsePower</td>
                            <td>@m.BodyTypeName</td>
                            <td>
                                <div class="admin-actions">
                                    <a asp-action="Edit" asp-route-id="@m.ModelId" class="btn btn-warning btn-admin-sm">Edit</a>
                                    <a asp-action="Delete" asp-route-id="@m.ModelId" class="btn btn-danger btn-admin-sm">Delete</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>