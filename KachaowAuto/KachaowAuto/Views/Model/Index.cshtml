@model IEnumerable<KachaowAuto.ViewModels.Model.ModelListViewModel>

<h2>Models</h2>

<a class="btn btn-primary mb-3" asp-action="Create">Create Model</a>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Brand</th>
            <th>Model</th>
            <th>Engine Type</th>
            <th>Volume</th>
            <th>HP</th>
            <th>Body Type</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var m in Model)
        {
            <tr>
                <td>@m.BrandName</td>
                <td>@m.ModelName</td>
                <td>@m.EngineTypeName</td>
                <td>@m.EngineVolume</td>
                <td>@m.HorsePower</td>
                <td>@m.BodyTypeName</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@m.ModelId" class="btn btn-warning btn-sm">Edit</a>
                    <a asp-action="Delete" asp-route-id="@m.ModelId" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>