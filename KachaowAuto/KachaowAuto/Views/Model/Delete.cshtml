@model KachaowAuto.ViewModels.Model.ModelDetailsViewModel

@{
    ViewData["Title"] = "Delete Model";
}

<div class="admin-page">
    <div class="admin-header">
        <div class="admin-title-wrap">
            <h1>Delete Model</h1>
            <p class="admin-subtitle">
                Review all model information before permanently removing it from the system.
            </p>
        </div>
    </div>

    <div class="admin-form-wrap">
        <div class="admin-form-card">
            <div class="admin-form-head">
                <h2 class="admin-form-title">Delete Confirmation</h2>
                <p class="admin-form-subtitle">This action cannot be undone.</p>
            </div>

            <div class="admin-form-body">
                <div class="admin-warning-box">
                    Are you sure you want to delete this model?
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="admin-info-box">
                            <span class="admin-info-label">Brand</span>
                            <div class="admin-info-value">@Model.BrandName</div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="admin-info-box">
                            <span class="admin-info-label">Model</span>
                            <div class="admin-info-value">@Model.ModelName</div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="admin-info-box">
                            <span class="admin-info-label">Engine Type</span>
                            <div class="admin-info-value">@Model.EngineTypeName</div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="admin-info-box">
                            <span class="admin-info-label">Engine Volume</span>
                            <div class="admin-info-value">@Model.EngineVolume</div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="admin-info-box">
                            <span class="admin-info-label">Horse Power</span>
                            <div class="admin-info-value">@Model.HorsePower</div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="admin-info-box">
                            <span class="admin-info-label">Body Type</span>
                            <div class="admin-info-value">@Model.BodyTypeName</div>
                        </div>
                    </div>
                </div>

                <form asp-action="DeleteConfirmed" method="post" class="mt-4">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.ModelId" />

                    <div class="admin-form-actions">
                        <button type="submit" class="btn btn-danger btn-admin">Delete</button>
                        <a asp-action="Index" class="btn btn-secondary btn-admin">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>