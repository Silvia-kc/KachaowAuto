@model IEnumerable<KachaowAuto.ViewModels.PartImage.PartImageListViewModel>

@{
    ViewData["Title"] = "Part Images";
}

<div class="admin-page">
    <div class="admin-header">
        <div class="admin-title-wrap">
            <h1>Part Images</h1>
            <p class="admin-subtitle">
                Manage all uploaded images for parts. Keep visuals clean and organized.
            </p>
        </div>

        <div class="admin-toolbar">
            <a asp-action="Create" class="btn btn-primary btn-admin">Add New Image</a>
        </div>
    </div>

    <div class="admin-stats">
        <div class="admin-stat-card">
            <div class="admin-stat-label">Total Images</div>
            <div class="admin-stat-value accent">@Model.Count()</div>
        </div>

        <div class="admin-stat-card">
            <div class="admin-stat-label">Module</div>
            <div class="admin-stat-value">Parts</div>
        </div>

        <div class="admin-stat-card">
            <div class="admin-stat-label">Type</div>
            <div class="admin-stat-value">Images</div>
        </div>
    </div>

    <div class="image-grid">
        @foreach (var image in Model)
        {
            <div class="image-card">
                <div class="image-card-img-wrap">
                    <img src="@image.ImageUrl" alt="@image.PartName" class="image-card-img" />
                </div>

                <div class="image-card-body">
                    <h4 class="image-card-title">@image.PartName</h4>

                    <form asp-action="Delete" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@image.PartImageId" />

                        <button type="submit" class="btn btn-danger btn-admin-sm w-100">
                            Delete Image
                        </button>
                    </form>
                </div>
            </div>
        }
    </div>
</div>