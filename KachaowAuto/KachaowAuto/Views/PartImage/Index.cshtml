@model IEnumerable<KachaowAuto.Data.Models.PartImage>

@{
    ViewData["Title"] = "Part Images";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Part Images</h2>
        <a asp-action="Create" class="btn btn-primary">Add New Image</a>
    </div>

    <div class="row">
        @foreach (var image in Model)
        {
            <div class="col-md-3 mb-4">
                <div class="card shadow-sm h-100">
                    <img src="@image.ImageUrl"
                         class="card-img-top"
                         alt="Part Image"
                         style="height: 220px; object-fit: cover;" />

                    <div class="card-body">
                        <h6 class="card-title">@image.Part?.PartName</h6>
                    </div>

                    <div class="card-footer bg-white border-0">
                        <form asp-action="Delete" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@image.PartImageId" />
                            <button type="submit" class="btn btn-danger btn-sm w-100">
                                Delete
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
</div>