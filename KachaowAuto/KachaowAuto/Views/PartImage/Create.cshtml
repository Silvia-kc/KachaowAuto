@model KachaowAuto.Data.Models.PartImage

@{
    ViewData["Title"] = "Add Part Image";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-4">
            <h2 class="mb-4">Add Image</h2>

            <form asp-controller="PartImage" asp-action="Create" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label">Part</label>
                    <select asp-for="PartId" asp-items="ViewBag.Parts" class="form-select"></select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Image</label>
                    <input type="file" name="imageFile" class="form-control" accept="image/*" />
                </div>

                <button type="submit" class="btn btn-primary">Upload</button>
                <a asp-controller="Part" asp-action="Index" class="btn btn-secondary">Back</a>
            </form>
        </div>
    </div>
</div>