@model KachaowAuto.ViewModels.PartImage.PartImageCreateViewModel

@{
    ViewData["Title"] = "Add Part Image";
}

<div class="admin-page">
    <div class="admin-header">
        <div class="admin-title-wrap">
            <h1>Add Image</h1>
            <p class="admin-subtitle">
                Upload a new image and assign it to a specific part.
            </p>
        </div>
    </div>

    <div class="admin-form-wrap">
        <div class="admin-form-card">
            <div class="admin-form-head">
                <h2 class="admin-form-title">Image Upload</h2>
                <p class="admin-form-subtitle">Select a part and upload a new image.</p>
            </div>

            <div class="admin-form-body">
                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="PartId" class="form-label">Part</label>
                        <select asp-for="PartId" class="form-select custom-select-dark"
                                asp-items="@(new SelectList(Model.Parts, "PartId", "PartName"))">
                            <option value="">-- Select part --</option>
                        </select>
                        <span asp-validation-for="PartId" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ImageFile" class="form-label">Image</label>
                        <input asp-for="ImageFile" type="file" class="form-control" accept="image/*" />
                        <span asp-validation-for="ImageFile" class="text-danger"></span>
                    </div>

                    <div class="admin-form-actions">
                        <a asp-controller="Part" asp-action="Index" class="btn btn-secondary btn-admin">Back</a>
                        <button type="submit" class="btn btn-primary btn-admin">Upload</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}