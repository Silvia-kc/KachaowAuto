@model KachaowAuto.ViewModels.PartImage.PartImageCreateViewModel

@{
    ViewData["Title"] = "Add Part Image";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-4">
            <h2 class="mb-4">Add Image</h2>

            <form asp-action="Create" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="PartId" class="form-label"></label>
                    <select asp-for="PartId" class="form-select"
                            asp-items="@(new SelectList(Model.Parts, "PartId", "PartName"))">
                        <option value="">-- select part --</option>
                    </select>
                    <span asp-validation-for="PartId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ImageFile" class="form-label"></label>
                    <input asp-for="ImageFile" type="file" class="form-control" accept="image/*" />
                    <span asp-validation-for="ImageFile" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary">Upload</button>
                <a asp-controller="Part" asp-action="Index" class="btn btn-secondary">Back</a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}