@model KachaowAuto.ViewModels.Brand.BrandCreateViewModel

@{
    ViewData["Title"] = "Create Brand";
}

<div class="admin-page">
    <div class="admin-header">
        <div class="admin-title-wrap">
            <h1>Create Brand</h1>
            <p class="admin-subtitle">
                Add a new vehicle brand to the system catalog.
            </p>
        </div>
    </div>

    <div class="admin-form-wrap">
        <div class="admin-form-card">
            <div class="admin-form-head">
                <h2 class="admin-form-title">Brand Information</h2>
                <p class="admin-form-subtitle">Enter the main details for the new brand.</p>
            </div>

            <div class="admin-form-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="BrandName" class="form-label">Brand Name</label>
                        <input asp-for="BrandName" class="form-control" placeholder="Enter brand name" />
                        <span asp-validation-for="BrandName" class="text-danger"></span>
                    </div>

                    <div class="admin-form-actions">
                        <button type="submit" class="btn btn-primary btn-admin">Save</button>
                        <a asp-action="Index" class="btn btn-secondary btn-admin">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}