@model IEnumerable<KachaowAuto.ViewModels.Brand.BrandListViewModel>

<h2>Brands</h2>

<a class="btn btn-primary mb-3" asp-action="Create">Create Brand</a>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Brand Name</th>
            <th>Models Count</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var b in Model)
        {
            <tr>
                <td>@b.BrandName</td>
                <td>@b.ModelsCount</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@b.BrandId" class="btn btn-warning btn-sm">Edit</a>
                    <a asp-action="Delete" asp-route-id="@b.BrandId" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>