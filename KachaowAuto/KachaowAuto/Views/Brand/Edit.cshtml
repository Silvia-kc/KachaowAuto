@model KachaowAuto.ViewModels.Brand.BrandEditViewModel

@{
    ViewData["Title"] = "Edit Brand";
}

<div class="admin-page">
    <div class="admin-header">
        <div class="admin-title-wrap">
            <h1>Edit Brand</h1>
            <p class="admin-subtitle">
                Update brand information and keep the catalog accurate.
            </p>
        </div>
    </div>

    <div class="admin-form-wrap">
        <div class="admin-form-card">
            <div class="admin-form-head">
                <h2 class="admin-form-title">Edit Brand Details</h2>
                <p class="admin-form-subtitle">Make changes to the selected vehicle brand.</p>
            </div>

            <div class="admin-form-body">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="BrandId" />

                    <div class="mb-3">
                        <label asp-for="BrandName" class="form-label">Brand Name</label>
                        <input asp-for="BrandName" class="form-control" placeholder="Enter brand name" />
                        <span asp-validation-for="BrandName" class="text-danger"></span>
                    </div>

                    <div class="admin-form-actions">
                        <button type="submit" class="btn btn-primary btn-admin">Save Changes</button>
                        <a asp-action="Index" class="btn btn-secondary btn-admin">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}