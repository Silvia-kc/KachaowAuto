@model KachaowAuto.ViewModels.BodyType.BodyTypeDetailsViewModel

@{
    ViewData["Title"] = "Delete Body Type";
}

<div class="admin-page">
    <div class="admin-header">
        <div class="admin-title-wrap">
            <h1>Delete Body Type</h1>
            <p class="admin-subtitle">
                Review the selected body type before permanently removing it from the system.
            </p>
        </div>
    </div>

    <div class="admin-form-wrap">
        <div class="admin-form-card">
            <div class="admin-form-head">
                <h2 class="admin-form-title">Delete Confirmation</h2>
                <p class="admin-form-subtitle">This action cannot be undone.</p>
            </div>

            <div class="admin-form-body">
                <div class="admin-warning-box">
                    Are you sure you want to delete this body type?
                </div>

                <div class="admin-info-box">
                    <span class="admin-info-label">Body Type Name</span>
                    <div class="admin-info-value">@Model.Name</div>
                </div>

                <form asp-action="DeleteConfirmed" method="post" class="mt-4">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.BodyTypeId" />

                    <div class="admin-form-actions">
                        <button type="submit" class="btn btn-danger btn-admin">Delete</button>
                        <a asp-action="Index" class="btn btn-secondary btn-admin">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>