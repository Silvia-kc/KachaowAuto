@model IEnumerable<KachaowAuto.ViewModels.BodyType.BodyTypeListViewModel>

@{
    ViewData["Title"] = "Body Types";
}

<div class="admin-page">
    <div class="admin-header">
        <div class="admin-title-wrap">
            <h1>Body Types</h1>
            <p class="admin-subtitle">
                Manage all vehicle body types and keep the catalog structure clean and organized.
            </p>
        </div>

        <div class="admin-toolbar">
            <a asp-action="Create" class="btn btn-primary btn-admin">Create Body Type</a>
        </div>
    </div>

    <div class="admin-stats">
        <div class="admin-stat-card">
            <div class="admin-stat-label">Total Body Types</div>
            <div class="admin-stat-value accent">@Model.Count()</div>
        </div>

        <div class="admin-stat-card">
            <div class="admin-stat-label">Catalog Section</div>
            <div class="admin-stat-value">Body Types</div>
        </div>

        <div class="admin-stat-card">
            <div class="admin-stat-label">Management Area</div>
            <div class="admin-stat-value">Admin</div>
        </div>
    </div>

    <div class="admin-panel">
        <div class="admin-panel-head">
            <div>
                <h2 class="admin-panel-title">Body Type Directory</h2>
                <p class="admin-panel-text">Browse, edit and manage all registered body types.</p>
            </div>
        </div>

        <div class="admin-table-wrap">
            <table class="table admin-table">
                <thead>
                    <tr>
                        <th>Body Type Name</th>
                        <th>Models Count</th>
                        <th style="width: 220px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var bt in Model)
                    {
                        <tr>
                            <td>@bt.Name</td>
                            <td>@bt.ModelsCount</td>
                            <td>
                                <div class="admin-actions">
                                    <a asp-action="Edit" asp-route-id="@bt.BodyTypeId" class="btn btn-warning btn-admin-sm">Edit</a>
                                    <a asp-action="Delete" asp-route-id="@bt.BodyTypeId" class="btn btn-danger btn-admin-sm">Delete</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>