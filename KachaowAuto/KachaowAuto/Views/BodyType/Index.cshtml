@model IEnumerable<KachaowAuto.ViewModels.BodyType.BodyTypeListViewModel>

<h2>Body Types</h2>

<a class="btn btn-primary mb-3" asp-action="Create">Create Body Type</a>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Body Type Name</th>
            <th>Models Count</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var bt in Model)
        {
            <tr>
                <td>@bt.Name</td>
                <td>@bt.ModelsCount</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@bt.BodyTypeId" class="btn btn-warning btn-sm">Edit</a>
                    <a asp-action="Delete" asp-route-id="@bt.BodyTypeId" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>