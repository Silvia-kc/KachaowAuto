@model IEnumerable<KachaowAuto.Data.Models.PartCategory>

@{
    ViewData["Title"] = "Part Categories";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Part Categories</h2>
        <a asp-action="Create" class="btn btn-primary">Add New Category</a>
    </div>

    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Parts Count</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var category in Model)
            {
                <tr>
                    <td>@category.Name</td>
                    <td>@category.Parts.Count</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@category.PartCategoryId" class="btn btn-warning btn-sm">Edit</a>
                        <a asp-action="Delete" asp-route-id="@category.PartCategoryId" class="btn btn-danger btn-sm">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
