@model KachaowAuto.ViewModels.PartCategory.PartCategoryCreateViewModel

@{
    ViewData["Title"] = "Create Part Category";
}

<div class="admin-page">
    <div class="admin-header">
        <div class="admin-title-wrap">
            <h1>Create Part Category</h1>
            <p class="admin-subtitle">
                Add a new category to organize parts in the system catalog.
            </p>
        </div>
    </div>

    <div class="admin-form-wrap">
        <div class="admin-form-card">
            <div class="admin-form-head">
                <h2 class="admin-form-title">Category Information</h2>
                <p class="admin-form-subtitle">Enter the main details for the new part category.</p>
            </div>

            <div class="admin-form-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Category Name</label>
                        <input asp-for="Name" class="form-control" placeholder="Enter category name" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="admin-form-actions">
                        <button type="submit" class="btn btn-primary btn-admin">Save</button>
                        <a asp-action="Index" class="btn btn-secondary btn-admin">Back</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}