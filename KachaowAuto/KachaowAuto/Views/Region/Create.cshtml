@model KachaowAuto.Data.Models.Region

@{
    ViewData["Title"] = "Create Region";
}

<div class="container mt-4">
    <h1 class="mb-4">Create Region</h1>

    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="RegionName" class="form-label"></label>
            <input asp-for="RegionName" class="form-control" />
            <span asp-validation-for="RegionName" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-success">Create</button>
        <a asp-action="Index" class="btn btn-secondary">Back</a>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
