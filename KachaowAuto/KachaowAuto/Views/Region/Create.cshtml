@model KachaowAuto.ViewModels.Region.RegionCreateViewModel

@{
    ViewData["Title"] = "Create Region";
}

<div class="admin-page">
    <div class="admin-header">
        <div class="admin-title-wrap">
            <h1>Create Region</h1>
            <p class="admin-subtitle">
                Add a new region to organize workshops by location.
            </p>
        </div>
    </div>

    <div class="admin-form-wrap">
        <div class="admin-form-card">
            <div class="admin-form-head">
                <h2 class="admin-form-title">Region Information</h2>
                <p class="admin-form-subtitle">Enter the main details for the new region.</p>
            </div>

            <div class="admin-form-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="RegionName" class="form-label">Region Name</label>
                        <input asp-for="RegionName" class="form-control" placeholder="Enter region name" />
                        <span asp-validation-for="RegionName" class="text-danger"></span>
                    </div>

                    <div class="admin-form-actions">
                        <button type="submit" class="btn btn-primary btn-admin">Create</button>
                        <a asp-action="Index" class="btn btn-secondary btn-admin">Back</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}