@model KachaowAuto.ViewModels.Region.RegionEditViewModel

@{
    ViewData["Title"] = "Edit Region";
}

<div class="admin-page">
    <div class="admin-header">
        <div class="admin-title-wrap">
            <h1>Edit Region</h1>
            <p class="admin-subtitle">
                Update region information and keep workshop locations properly organized.
            </p>
        </div>
    </div>

    <div class="admin-form-wrap">
        <div class="admin-form-card">
            <div class="admin-form-head">
                <h2 class="admin-form-title">Edit Region Details</h2>
                <p class="admin-form-subtitle">Make changes to the selected region.</p>
            </div>

            <div class="admin-form-body">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="RegionId" />

                    <div class="mb-3">
                        <label asp-for="RegionName" class="form-label">Region Name</label>
                        <input asp-for="RegionName" class="form-control" placeholder="Enter region name" />
                        <span asp-validation-for="RegionName" class="text-danger"></span>
                    </div>

                    <div class="admin-form-actions">
                        <button type="submit" class="btn btn-primary btn-admin">Save</button>
                        <a asp-action="Index" class="btn btn-secondary btn-admin">Back</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}