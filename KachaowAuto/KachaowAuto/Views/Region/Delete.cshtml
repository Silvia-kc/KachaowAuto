@model KachaowAuto.ViewModels.Region.RegionDetailsViewModel

@{
    ViewData["Title"] = "Delete Region";
}

<div class="container mt-4">
    <h1 class="mb-4">Delete Region</h1>

    <div class="alert alert-warning">
        Are you sure you want to delete this region?
    </div>

    <div class="mb-3">
        <strong>Region Name:</strong> @Model.RegionName
    </div>

    <form asp-action="DeleteConfirmed" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.RegionId" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>