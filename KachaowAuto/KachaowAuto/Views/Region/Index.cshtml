@model IEnumerable<KachaowAuto.Data.Models.Region>

@{
    ViewData["Title"] = "Regions";
}

<div class="container mt-4">
    <h1 class="mb-4">Regions</h1>

    <p>
        <a asp-action="Create" class="btn btn-primary">Create Region</a>
    </p>

    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Id</th>
                <th>Region Name</th>
                <th>Workshops Count</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var region in Model)
            {
                <tr>
                    <td>@region.RegionId</td>
                    <td>@region.RegionName</td>
                    <td>@(region.Workshops?.Count ?? 0)</td>
                </tr>
            }
        </tbody>
    </table>
</div>
