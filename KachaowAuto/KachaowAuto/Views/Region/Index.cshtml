@model IEnumerable<KachaowAuto.ViewModels.Region.RegionListViewModel>

@{
    ViewData["Title"] = "Regions";
}

<div class="admin-page">
    <div class="admin-header">
        <div class="admin-title-wrap">
            <h1>Regions</h1>
            <p class="admin-subtitle">
                Manage all regions and track how many workshops are assigned to each one.
            </p>
        </div>

        <div class="admin-toolbar">
            <a asp-action="Create" class="btn btn-primary btn-admin">Create Region</a>
        </div>
    </div>

    <div class="admin-stats">
        <div class="admin-stat-card">
            <div class="admin-stat-label">Total Regions</div>
            <div class="admin-stat-value accent">@Model.Count()</div>
        </div>

        <div class="admin-stat-card">
            <div class="admin-stat-label">Catalog Section</div>
            <div class="admin-stat-value">Regions</div>
        </div>

        <div class="admin-stat-card">
            <div class="admin-stat-label">Management Area</div>
            <div class="admin-stat-value">Admin</div>
        </div>
    </div>

    <div class="admin-panel">
        <div class="admin-panel-head">
            <div>
                <h2 class="admin-panel-title">Region Directory</h2>
                <p class="admin-panel-text">Browse, edit and manage all registered regions.</p>
            </div>
        </div>

        <div class="admin-table-wrap">
            <table class="table admin-table">
                <thead>
                    <tr>
                        <th>Id</th>
                        <th>Region Name</th>
                        <th>Workshops Count</th>
                        <th style="width: 220px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var region in Model)
                    {
                        <tr>
                            <td>@region.RegionId</td>
                            <td>@region.RegionName</td>
                            <td>@region.WorkshopsCount</td>
                            <td>
                                <div class="admin-actions">
                                    <a asp-action="Edit" asp-route-id="@region.RegionId" class="btn btn-warning btn-admin-sm">Edit</a>
                                    <a asp-action="Delete" asp-route-id="@region.RegionId" class="btn btn-danger btn-admin-sm">Delete</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>