@model IEnumerable<KachaowAuto.ViewModels.Region.RegionListViewModel>

@{
    ViewData["Title"] = "Regions";
}

<div class="container mt-4">
    <h1 class="mb-4">Regions</h1>

    <p>
        <a asp-action="Create" class="btn btn-primary">Create Region</a>
    </p>

    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Id</th>
                <th>Region Name</th>
                <th>Workshops Count</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var region in Model)
            {
                <tr>
                    <td>@region.RegionId</td>
                    <td>@region.RegionName</td>
                    <td>@region.WorkshopsCount</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@region.RegionId" class="btn btn-warning btn-sm">Edit</a>
                        <a asp-action="Delete" asp-route-id="@region.RegionId" class="btn btn-danger btn-sm">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>