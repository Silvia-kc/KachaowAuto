@model IEnumerable<KachaowAuto.ViewModels.ServiceCategory.ServiceCategoryListViewModel>

@{
    ViewData["Title"] = "Service Categories";
}

<div class="container mt-4">
    <h1>Service Categories</h1>

    <p>
        <a asp-action="Create" class="btn btn-primary">Create Service Category</a>
    </p>

    <table class="table">
        <thead>
            <tr>
                <th>Category Name</th>
                <th>Services Count</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var category in Model)
            {
                <tr>
                    <td>@category.CategoryName</td>
                    <td>@category.ServicesCount</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@category.ServiceCategoryId" class="btn btn-warning btn-sm">Edit</a>
                        <a asp-action="Delete" asp-route-id="@category.ServiceCategoryId" class="btn btn-danger btn-sm">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>