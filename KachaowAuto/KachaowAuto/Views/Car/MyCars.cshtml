@model IEnumerable<KachaowAuto.ViewModels.Car.MyCarViewModel>

@{
    ViewData["Title"] = "My Cars";
}

<div class="client-cars-page">
    <section class="client-cars-header">
        <div>
            <div class="client-cars-badge">My Garage</div>
            <h1 class="client-cars-title">My Cars</h1>
            <p class="client-cars-subtitle">
                View your vehicles and check their latest service status.
            </p>
        </div>

    </section>

    @if (Model == null || !Model.Any())
    {
        <div class="client-cars-empty">
            <h3>No cars added yet</h3>
            <p>Your garage is currently empty. Add your first car to get started.</p>
            <a asp-controller="Car" asp-action="Create" class="btn btn-primary btn-admin">
                Add First Car
            </a>
        </div>
    }
    else
    {
        <div class="client-cars-grid">
            @foreach (var car in Model)
            {
                <div class="client-car-card">
                    <div class="client-car-top">
                        <div>
                            <div class="client-car-brand">@car.BrandName</div>
                            <h3 class="client-car-model">@car.ModelName</h3>
                        </div>

                        <div class="client-car-year">@car.Year</div>
                    </div>

                    <div class="client-car-details">
                        <div class="client-car-detail">
                            <span class="client-car-label">License Plate</span>
                            <span class="client-car-value">@car.VIN</span>
                        </div>

                        <div class="client-car-detail">
                            <span class="client-car-label">Latest Status</span>
                            <span class="client-car-value">
                                @if (car.LatestStatus == "Completed")
                                {
                                    <span class="badge-status badge-status-sent">Completed</span>
                                }
                                else if (car.LatestStatus == "Upcoming")
                                {
                                    <span class="badge-status badge-status-pending">Upcoming</span>
                                }
                                else if (car.LatestStatus == "In Progress")
                                {
                                    <span class="badge-status badge-status-approved">In Progress</span>
                                }
                                else
                                {
                                    <span class="badge-status">No appointments</span>
                                }
                            </span>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>