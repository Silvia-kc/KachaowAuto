@model IEnumerable<KachaowAuto.ViewModels.PartRequest.PartRequestMyRequestViewModel>

@{
    ViewData["Title"] = "My Requests";
}

<div class="admin-page">
    <div class="admin-header">
        <div class="admin-title-wrap">
            <h1>My Part Requests</h1>
            <p class="admin-subtitle">
                Track your submitted requests, status changes and admin responses.
            </p>
        </div>
    </div>

    <div class="admin-stats">
        <div class="admin-stat-card">
            <div class="admin-stat-label">My Requests</div>
            <div class="admin-stat-value accent">@Model.Count()</div>
        </div>

        <div class="admin-stat-card">
            <div class="admin-stat-label">Module</div>
            <div class="admin-stat-value">Parts</div>
        </div>

        <div class="admin-stat-card">
            <div class="admin-stat-label">View</div>
            <div class="admin-stat-value">Mechanic</div>
        </div>
    </div>

    <div class="admin-panel">
        <div class="admin-panel-head">
            <div>
                <h2 class="admin-panel-title">Request History</h2>
                <p class="admin-panel-text">Review the progress and final response for each request.</p>
            </div>
        </div>

        <div class="admin-table-wrap">
            <table class="table admin-table">
                <thead>
                    <tr>
                        <th>Part</th>
                        <th>Quantity</th>
                        <th>Status</th>
                        <th>Requested</th>
                        <th>Processed</th>
                        <th>Note</th>
                        <th>Admin Note</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        <tr>
                            <td>@r.PartName</td>
                            <td>@r.Quantity</td>
                            <td>
                                @if (r.Status == "Pending")
                                {
                                    <span class="badge-status badge-status-pending">Pending</span>
                                }
                                else if (r.Status == "Approved")
                                {
                                    <span class="badge-status badge-status-approved">Approved</span>
                                }
                                else if (r.Status == "Rejected")
                                {
                                    <span class="badge-status badge-status-rejected">Rejected</span>
                                }
                                else if (r.Status == "Sent")
                                {
                                    <span class="badge-status badge-status-sent">Sent</span>
                                }
                                else
                                {
                                    <span class="badge-status">@r.Status</span>
                                }
                            </td>
                            <td>@r.RequestedAt.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@(r.ProcessedAt?.ToString("dd.MM.yyyy HH:mm") ?? "-")</td>
                            <td>@(string.IsNullOrWhiteSpace(r.Note) ? "-" : r.Note)</td>
                            <td>@(string.IsNullOrWhiteSpace(r.AdminNote) ? "-" : r.AdminNote)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>