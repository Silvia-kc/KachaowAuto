@model KachaowAuto.ViewModels.PartRequest.PartRequestCreateViewModel

@{
    ViewData["Title"] = "Request Part";
}

<div class="admin-page">
    <div class="admin-header">
        <div class="admin-title-wrap">
            <h1>Request Part</h1>
            <p class="admin-subtitle">
                Submit a new part request with quantity and additional notes.
            </p>
        </div>
    </div>

    <div class="admin-form-wrap">
        <div class="admin-form-card">
            <div class="admin-form-head">
                <h2 class="admin-form-title">Request Information</h2>
                <p class="admin-form-subtitle">Review the selected part and enter your request details.</p>
            </div>

            <div class="admin-form-body">
                <form asp-controller="PartRequest" asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <input type="hidden" asp-for="PartId" />
                    <input type="hidden" asp-for="PartName" />

                    <div class="mb-3">
                        <label class="form-label">Part</label>
                        <input class="form-control readonly-dark-input" value="@Model.PartName" readonly />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Quantity" class="form-label">Quantity</label>
                        <input asp-for="Quantity" class="form-control" placeholder="Enter quantity" />
                        <span asp-validation-for="Quantity" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Note" class="form-label">Note</label>
                        <textarea asp-for="Note" class="form-control" rows="4" placeholder="Add note if needed"></textarea>
                        <span asp-validation-for="Note" class="text-danger"></span>
                    </div>

                    <div class="admin-form-actions">
                        <a asp-controller="Part" asp-action="Index" class="btn btn-secondary btn-admin">Back</a>
                        <button type="submit" class="btn btn-primary btn-admin">Submit Request</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}