@{
    ViewData["Title"] = "Client Dashboard";
}

<div class="client-portal-clean">
    <section class="client-clean-header">
        <div class="client-clean-badge">Client Portal</div>
        <h1 class="client-clean-title">Welcome back</h1>
        <p class="client-clean-subtitle">
            Manage your cars, appointments and workshops in one place.
        </p>
    </section>

    <section class="client-clean-grid">
        <a asp-controller="Appointment" asp-action="Create" class="client-clean-card client-clean-card-main">
            <div class="client-clean-card-overlay"></div>

            <div class="client-clean-card-content">
                <div class="client-clean-kicker">Main Action</div>
                <h2>Book Appointment</h2>
                <p>Schedule your next visit quickly and keep your service process simple.</p>
                <span class="client-clean-link">Open booking</span>
            </div>
        </a>

        <a asp-controller="Car" asp-action="MyCars" class="client-clean-card client-clean-card-side">
            <div class="client-clean-side-top">Garage</div>
            <h3>My Cars</h3>
            <p>View your vehicles and keep your personal garage organized.</p>
            <span class="client-clean-link">Open garage</span>
        </a>

        <a asp-controller="Workshop" asp-action="Index" class="client-clean-card client-clean-card-side">
            <div class="client-clean-side-top">Locations</div>
            <h3>Workshops</h3>
            <p>Explore workshops and find the best location for service.</p>
            <span class="client-clean-link">Open workshops</span>
        </a>
    </section>
</div>