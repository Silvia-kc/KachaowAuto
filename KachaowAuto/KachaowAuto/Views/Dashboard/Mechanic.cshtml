@{
    ViewData["Title"] = "Mechanic Dashboard";
}

<div class="mechanic-clean-page">

    <section class="mechanic-clean-hero">
        <div class="mechanic-clean-badge">Mechanic Portal</div>

        <h1 class="mechanic-clean-title">Mechanic Dashboard</h1>

        <p class="mechanic-clean-subtitle">
            Manage appointments, parts and requests in one place.
        </p>
    </section>

    <section class="mechanic-clean-actions">
        <div class="row g-4">

            <div class="col-md-6 col-xl-4">
                <a asp-controller="Appointment" asp-action="Index" class="mechanic-clean-card primary">
                    <div class="mechanic-clean-line"></div>

                    <h3>Appointments</h3>
                    <p>Manage customer bookings and workflow.</p>

                    <span class="mechanic-clean-link">Open</span>
                </a>
            </div>

            <div class="col-md-6 col-xl-4">
                <a asp-controller="Part" asp-action="Index" class="mechanic-clean-card">
                    <div class="mechanic-clean-line"></div>

                    <h3>Parts</h3>
                    <p>Browse and manage repair parts.</p>

                    <span class="mechanic-clean-link">Open</span>
                </a>
            </div>

            <div class="col-md-6 col-xl-4">
                <a asp-controller="PartRequest" asp-action="MyRequests" class="mechanic-clean-card">
                    <div class="mechanic-clean-line"></div>

                    <h3>My Requests</h3>
                    <p>Track requested parts and statuses.</p>

                    <span class="mechanic-clean-link">Open</span>
                </a>
            </div>

        </div>
    </section>

</div>