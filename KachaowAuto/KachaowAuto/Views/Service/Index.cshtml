@model IEnumerable<KachaowAuto.ViewModels.Service.ServiceListViewModel>

@{
    ViewData["Title"] = "Services";
}

<div class="admin-page">
    <div class="admin-header">
        <div class="admin-title-wrap">
            <h1>Services</h1>
            <p class="admin-subtitle">
                Manage all services, pricing ranges and service categories in the platform.
            </p>
        </div>

        <div class="admin-toolbar">
            <a asp-action="Create" class="btn btn-primary btn-admin">Create Service</a>
        </div>
    </div>

    <div class="admin-stats">
        <div class="admin-stat-card">
            <div class="admin-stat-label">Total Services</div>
            <div class="admin-stat-value accent">@Model.Count()</div>
        </div>

        <div class="admin-stat-card">
            <div class="admin-stat-label">Catalog Section</div>
            <div class="admin-stat-value">Services</div>
        </div>

        <div class="admin-stat-card">
            <div class="admin-stat-label">Management Area</div>
            <div class="admin-stat-value">Admin</div>
        </div>
    </div>

    <div class="admin-panel">
        <div class="admin-panel-head">
            <div>
                <h2 class="admin-panel-title">Service Directory</h2>
                <p class="admin-panel-text">Browse, edit and manage all registered services.</p>
            </div>
        </div>

        <div class="admin-table-wrap">
            <table class="table admin-table">
                <thead>
                    <tr>
                        <th>Id</th>
                        <th>Service Name</th>
                        <th>Description</th>
                        <th>Price From</th>
                        <th>Price To</th>
                        <th>Category</th>
                        <th style="width: 220px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var service in Model)
                    {
                        <tr>
                            <td>@service.ServiceId</td>
                            <td>@service.ServiceName</td>
                            <td>@service.Description</td>
                            <td>@service.PriceFrom</td>
                            <td>@service.PriceTo</td>
                            <td>@service.CategoryName</td>
                            <td>
                                <div class="admin-actions">
                                    <a asp-action="Edit" asp-route-id="@service.ServiceId" class="btn btn-warning btn-admin-sm">Edit</a>
                                    <a asp-action="Delete" asp-route-id="@service.ServiceId" class="btn btn-danger btn-admin-sm">Delete</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>