@model KachaowAuto.ViewModels.Service.ServiceDetailsViewModel

@{
    ViewData["Title"] = "Delete Service";
}

<div class="admin-page">
    <div class="admin-header">
        <div class="admin-title-wrap">
            <h1>Delete Service</h1>
            <p class="admin-subtitle">
                Review the selected service before permanently removing it from the system.
            </p>
        </div>
    </div>

    <div class="admin-form-wrap admin-form-wide">
        <div class="admin-form-card">
            <div class="admin-form-head">
                <h2 class="admin-form-title">Delete Confirmation</h2>
                <p class="admin-form-subtitle">This action cannot be undone.</p>
            </div>

            <div class="admin-form-body">
                <div class="admin-warning-box">
                    Are you sure you want to delete this service?
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="admin-info-box">
                            <span class="admin-info-label">Service Name</span>
                            <div class="admin-info-value">@Model.ServiceName</div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="admin-info-box">
                            <span class="admin-info-label">Category</span>
                            <div class="admin-info-value">@Model.CategoryName</div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="admin-info-box">
                            <span class="admin-info-label">Price From</span>
                            <div class="admin-info-value">@Model.PriceFrom</div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="admin-info-box">
                            <span class="admin-info-label">Price To</span>
                            <div class="admin-info-value">@Model.PriceTo</div>
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="admin-info-box">
                            <span class="admin-info-label">Description</span>
                            <div class="admin-info-value part-description-value">@Model.Description</div>
                        </div>
                    </div>
                </div>

                <form asp-action="DeleteConfirmed" method="post" class="mt-4">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.ServiceId" />

                    <div class="admin-form-actions">
                        <button type="submit" class="btn btn-danger btn-admin">Delete</button>
                        <a asp-action="Index" class="btn btn-secondary btn-admin">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>