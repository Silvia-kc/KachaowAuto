@model KachaowAuto.ViewModels.BookAppointmentViewModel

@{
    ViewData["Title"] = "Book Appointment";
}

<div class="admin-page">
    <div class="admin-header">
        <div class="admin-title-wrap">
            <h1>Book Appointment</h1>
            <p class="admin-subtitle">
                Enter your vehicle details, choose a service and select a workshop.
            </p>
        </div>
    </div>

    <div class="admin-form-wrap admin-form-wide">
        <div class="admin-form-card">
            <div class="admin-form-head">
                <h2 class="admin-form-title">Appointment Information</h2>
                <p class="admin-form-subtitle">Complete the form below to schedule your visit.</p>
            </div>

            <div class="admin-form-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Brand</label>
                            <select class="form-select custom-select-dark" asp-for="BrandId" id="brandSelect">
                                <option value="">-- select brand --</option>
                                @foreach (var b in ViewBag.Brands)
                                {
                                    <option value="@b.BrandId" selected="@(Model.BrandId == b.BrandId)">
                                        @b.BrandName
                                    </option>
                                }
                            </select>
                            <span asp-validation-for="BrandId" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Model</label>
                            <select class="form-select custom-select-dark"
                                    asp-for="ModelId"
                                    id="modelSelect"
                                    disabled="@(Model.BrandId == 0)">
                                <option value="">-- select model --</option>
                            </select>
                            <span asp-validation-for="ModelId" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Year</label>
                            <input class="form-control" asp-for="Year" type="number" placeholder="Enter year" />
                            <span asp-validation-for="Year" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">VIN</label>
                            <input class="form-control" asp-for="VIN" placeholder="Enter VIN" />
                            <span asp-validation-for="VIN" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Engine Type</label>
                            <select class="form-select custom-select-dark" asp-for="EngineTypeId" id="engineTypeSelect">
                                <option value="">-- select engine type --</option>
                                @foreach (var e in ViewBag.EngineTypes)
                                {
                                    <option value="@e.EngineTypeId" selected="@(Model.EngineTypeId == e.EngineTypeId)">
                                        @e.Name
                                    </option>
                                }
                            </select>
                            <span asp-validation-for="EngineTypeId" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Body Type</label>
                            <select class="form-select custom-select-dark" asp-for="BodyTypeId" id="bodyTypeSelect">
                                <option value="">-- select body type --</option>
                                @foreach (var b in ViewBag.BodyTypes)
                                {
                                    <option value="@b.BodyTypeId" selected="@(Model.BodyTypeId == b.BodyTypeId)">
                                        @b.Name
                                    </option>
                                }
                            </select>
                            <span asp-validation-for="BodyTypeId" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Service</label>
                            <select class="form-select custom-select-dark" asp-for="ServiceId">
                                <option value="">-- select service --</option>
                                @foreach (var s in ViewBag.Services)
                                {
                                    <option value="@s.ServiceId" selected="@(Model.ServiceId == s.ServiceId)">
                                        @s.ServiceName
                                    </option>
                                }
                            </select>
                            <span asp-validation-for="ServiceId" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Workshop</label>
                            <select class="form-select custom-select-dark" asp-for="WorkshopId" id="workshopSelect">
                                <option value="">-- select workshop --</option>
                                @foreach (var w in ViewBag.Workshops)
                                {
                                    <option value="@w.WorkshopId" selected="@(Model.WorkshopId == w.WorkshopId)">
                                        @w.Name (@w.Region?.RegionName)
                                    </option>
                                }
                            </select>
                            <span asp-validation-for="WorkshopId" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Scheduled Date</label>
                        <input class="form-control custom-date-dark"
                               asp-for="ScheduledDate"
                               type="datetime-local"
                               value="@Model.ScheduledDate.ToString("yyyy-MM-ddTHH:mm")" />
                        <span asp-validation-for="ScheduledDate" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Problem Description</label>
                        <textarea class="form-control"
                                  asp-for="ProblemDescription"
                                  rows="4"
                                  placeholder="Describe the issue or service need"></textarea>
                        <span asp-validation-for="ProblemDescription" class="text-danger"></span>
                    </div>

                    <div class="admin-form-actions">
                        <button type="submit" class="btn btn-primary btn-admin">Book Appointment</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const brandSelect = document.getElementById('brandSelect');
        const modelSelect = document.getElementById('modelSelect');

        async function loadModels(brandId, selectedModelId) {
            modelSelect.innerHTML = '<option value="">-- select model --</option>';
            modelSelect.disabled = true;

            if (!brandId) return;

            const res = await fetch(`/Appointment/GetModelsByBrand?brandId=${brandId}`);
            if (!res.ok) return;

            const models = await res.json();

            for (const m of models) {
                const opt = document.createElement('option');
                opt.value = m.id;
                opt.textContent = m.name;

                if (selectedModelId && String(m.id) === String(selectedModelId)) {
                    opt.selected = true;
                }

                modelSelect.appendChild(opt);
            }

            modelSelect.disabled = models.length === 0;
        }

        brandSelect.addEventListener('change', (e) => loadModels(e.target.value, null));

        if (brandSelect.value) {
            loadModels(brandSelect.value, '@Model.ModelId');
        }
    </script>
}