@model IEnumerable<KachaowAuto.ViewModels.Appointment.AppointmentIndexViewModel>

@{
    ViewData["Title"] = "Appointments";
}

<h2 class="mb-4">Appointments</h2>

<table class="table table-striped table-bordered align-middle">
    <thead class="table-dark">
        <tr>
            <th>Car</th>
            <th>VIN</th>
            <th>Service</th>
            <th>Workshop</th>
            <th>Status</th>
            <th>Scheduled</th>
            <th>Created</th>
            <th>Completed</th>
            <th>Problem</th>
            <th style="width: 260px;">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var a in Model)
        {
            <tr>
                <td>@a.CarModelName</td>
                <td>@a.VIN</td>
                <td>@a.ServiceName</td>
                <td>@a.WorkshopName</td>
                <td>
                    <span class="badge bg-secondary">@a.StatusName</span>
                </td>
                <td>@a.ScheduledDate.ToString("dd.MM.yyyy HH:mm")</td>
                <td>@a.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                <td>@(a.CompletedAt?.ToString("dd.MM.yyyy HH:mm") ?? "-")</td>
                <td>@(string.IsNullOrWhiteSpace(a.ProblemDescription) ? "-" : a.ProblemDescription)</td>
                <td>
                    <div class="d-flex gap-2 flex-wrap">
                        <a class="btn btn-sm btn-outline-secondary"
                           asp-action="Details"
                           asp-route-id="@a.AppointmentId">
                            View Details
                        </a>

                        <form asp-action="ChangeStatus" method="post" class="d-flex gap-2">
                            <input type="hidden" name="id" value="@a.AppointmentId" />

                            <select name="statusId" class="form-select form-select-sm" style="width: 140px;">
                                @foreach (var s in (IEnumerable<dynamic>)ViewBag.Statuses)
                                {
                                    if (a.AppointmentStatusId == s.AppointmentStatusId)
                                    {
                                        <option value="@s.AppointmentStatusId" selected>
                                            @s.StatusName
                                        </option>
                                    }
                                    else
                                    {
                                        <option value="@s.AppointmentStatusId">
                                            @s.StatusName
                                        </option>
                                    }
                                }
                            </select>

                            <button type="submit" class="btn btn-sm btn-primary">
                                Change
                            </button>
                        </form>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>