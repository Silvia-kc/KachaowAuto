@model KachaowAuto.ViewModels.Appointment.AppointmentIndexPageViewModel

@{
    ViewData["Title"] = "Appointments";
}

<div class="mechanic-appointments-page">
    <div class="mechanic-appointments-header">
        <div>
            <div class="mechanic-appointments-badge">Mechanic Workflow</div>
            <h1 class="mechanic-appointments-title">Appointments</h1>
            <p class="mechanic-appointments-subtitle">
                View customer bookings, track service progress and update appointment statuses.
            </p>
        </div>
    </div>

    <div class="mechanic-appointments-panel mechanic-filter-panel mb-4">
        <form asp-action="Index" method="get" class="mechanic-filter-form">
            <div class="mechanic-filter-grid">
                <div class="mechanic-filter-item">
                    <label asp-for="Filter.StatusId" class="mechanic-filter-label">Status</label>
                    <select asp-for="Filter.StatusId" class="form-select mechanic-filter-input">
                        <option value="">All statuses</option>
                        @foreach (var status in Model.Statuses)
                        {
                            <option value="@status.AppointmentStatusId">@status.StatusName</option>
                        }
                    </select>
                </div>

                <div class="mechanic-filter-item">
                    <label asp-for="Filter.ServiceId" class="mechanic-filter-label">Service</label>
                    <select asp-for="Filter.ServiceId" class="form-select mechanic-filter-input">
                        <option value="">All services</option>
                        @foreach (var service in Model.Services)
                        {
                            <option value="@service.ServiceId">@service.ServiceName</option>
                        }
                    </select>
                </div>

                <div class="mechanic-filter-item">
                    <label asp-for="Filter.FromDate" class="mechanic-filter-label">From date</label>
                    <input asp-for="Filter.FromDate" type="date" class="form-control mechanic-filter-input" />
                </div>

                <div class="mechanic-filter-item">
                    <label asp-for="Filter.ToDate" class="mechanic-filter-label">To date</label>
                    <input asp-for="Filter.ToDate" type="date" class="form-control mechanic-filter-input" />
                </div>

                <div class="mechanic-filter-item">
                    <label asp-for="Filter.SearchTerm" class="mechanic-filter-label">Car / License Plate</label>
                    <input asp-for="Filter.SearchTerm" class="form-control mechanic-filter-input" placeholder="Model or VIN" />
                </div>
            </div>

            <div class="mechanic-filter-actions">
                <button type="submit" class="btn mechanic-filter-btn-primary">
                    Filter
                </button>

                <a asp-action="Index" class="btn mechanic-filter-btn-secondary">
                    Clear
                </a>
            </div>
        </form>
    </div>

    <div class="mechanic-appointments-panel">
        <div class="mechanic-appointments-table-wrap">
            <table class="table mechanic-appointments-table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Car</th>
                        <th>License plate</th>
                        <th>Service</th>
                        <th>Workshop</th>
                        <th>Status</th>
                        <th>Scheduled</th>
                        <th>Created</th>
                        <th>Completed</th>
                        <th>Problem</th>
                        <th style="width: 300px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Appointments.Any())
                    {
                        <tr>
                            <td colspan="10" class="text-center">No appointments found.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var a in Model.Appointments)
                        {
                            <tr>
                                <td>@a.CarModelName</td>
                                <td>@a.VIN</td>
                                <td>@a.ServiceName</td>
                                <td>@a.WorkshopName</td>
                                <td>
                                    @if (a.StatusName == "Pending")
                                    {
                                        <span class="badge-status badge-status-pending">Pending</span>
                                    }
                                    else if (a.StatusName == "In Progress")
                                    {
                                        <span class="badge-status badge-status-approved">In Progress</span>
                                    }
                                    else if (a.StatusName == "Completed")
                                    {
                                        <span class="badge-status badge-status-sent">Completed</span>
                                    }
                                    else if (a.StatusName == "Cancelled")
                                    {
                                        <span class="badge-status badge-status-rejected">Cancelled</span>
                                    }
                                    else
                                    {
                                        <span class="badge-status">@a.StatusName</span>
                                    }
                                </td>
                                <td>@a.ScheduledDate.ToString("dd.MM.yyyy HH:mm")</td>
                                <td>@a.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                                <td>@(a.CompletedAt?.ToString("dd.MM.yyyy HH:mm") ?? "-")</td>
                                <td class="mechanic-problem-cell">
                                    @(string.IsNullOrWhiteSpace(a.ProblemDescription) ? "-" : a.ProblemDescription)
                                </td>
                                <td>
                                    <div class="mechanic-action-stack">
                                        <a class="btn btn-sm btn-admin-outline mechanic-details-btn"
                                           asp-action="Details"
                                           asp-route-id="@a.AppointmentId">
                                            View Details
                                        </a>

                                        <form asp-action="ChangeStatus" method="post" class="mechanic-status-form">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@a.AppointmentId" />

                                            <select name="statusId" class="form-select form-select-sm custom-select-dark mechanic-status-select">
                                                @foreach (var s in Model.Statuses)
                                                {
                                                    if (a.AppointmentStatusId == s.AppointmentStatusId)
                                                    {
                                                        <option value="@s.AppointmentStatusId" selected>
                                                            @s.StatusName
                                                        </option>
                                                    }
                                                    else
                                                    {
                                                        <option value="@s.AppointmentStatusId">
                                                            @s.StatusName
                                                        </option>
                                                    }
                                                }
                                            </select>

                                            <button type="submit" class="btn btn-sm btn-primary mechanic-change-btn">
                                                Change
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>