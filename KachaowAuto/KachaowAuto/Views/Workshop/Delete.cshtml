@model KachaowAuto.ViewModels.Workshop.WorkshopDetailsViewModel

@{
    ViewData["Title"] = "Delete Workshop";
}

<div class="admin-page">
    <div class="admin-header">
        <div class="admin-title-wrap">
            <h1>Delete Workshop</h1>
            <p class="admin-subtitle">
                Review the selected workshop before permanently removing it from the system.
            </p>
        </div>
    </div>

    <div class="admin-form-wrap admin-form-wide">
        <div class="admin-form-card">
            <div class="admin-form-head">
                <h2 class="admin-form-title">Delete Confirmation</h2>
                <p class="admin-form-subtitle">This action cannot be undone.</p>
            </div>

            <div class="admin-form-body">
                <div class="admin-warning-box">
                    Are you sure you want to delete this workshop?
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="admin-info-box">
                            <span class="admin-info-label">Workshop Name</span>
                            <div class="admin-info-value">@Model.Name</div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="admin-info-box">
                            <span class="admin-info-label">Region</span>
                            <div class="admin-info-value">@Model.RegionName</div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="admin-info-box">
                            <span class="admin-info-label">City</span>
                            <div class="admin-info-value">@Model.City</div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="admin-info-box">
                            <span class="admin-info-label">Phone</span>
                            <div class="admin-info-value">@(!string.IsNullOrWhiteSpace(Model.PhoneNumber) ? Model.PhoneNumber : "-")</div>
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="admin-info-box">
                            <span class="admin-info-label">Address</span>
                            <div class="admin-info-value">@Model.Address</div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="admin-info-box">
                            <span class="admin-info-label">Latitude</span>
                            <div class="admin-info-value">@Model.Latitude</div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="admin-info-box">
                            <span class="admin-info-label">Longitude</span>
                            <div class="admin-info-value">@Model.Longitude</div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="admin-info-box">
                            <span class="admin-info-label">Active</span>
                            <div class="admin-info-value">@(Model.IsActive ? "Yes" : "No")</div>
                        </div>
                    </div>
                </div>

                <form asp-action="DeleteConfirmed" method="post" class="mt-4">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.WorkshopId" />

                    <div class="admin-form-actions">
                        <button type="submit" class="btn btn-danger btn-admin">Delete</button>
                        <a asp-action="AdminIndex" class="btn btn-secondary btn-admin">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>