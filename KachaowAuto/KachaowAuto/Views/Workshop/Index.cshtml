@model KachaowAuto.ViewModels.Workshop.WorkshopMapViewModel
@using System.Globalization
@using System.Text.Encodings.Web

@{
    ViewData["Title"] = "Workshops";
    var cities = ViewBag.Cities as List<string> ?? new List<string>();
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<div class="container py-5 workshop-page">
    <div class="workshop-header text-center mb-4">
        <h1 class="workshop-title">Find a Workshop</h1>
        <p class="workshop-subtitle">Choose your city and explore available workshops on the map.</p>
    </div>

    <div class="workshop-filter-card mb-4">
        <form method="get" asp-action="Index">
            <div class="row g-3 align-items-end">
                <div class="col-md-9">
                    <label class="form-label workshop-label">Select city</label>
                    <select name="city" class="form-select form-select-lg rounded-4 custom-select-dark">
                        <option value="">All cities</option>
                        @foreach (var city in cities)
                        {
                            if (Model.SelectedCity == city)
                            {
                                <option value="@city" selected>@city</option>
                            }
                            else
                            {
                                <option value="@city">@city</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary btn-lg w-100 rounded-4 workshop-search-btn">
                        Search
                    </button>
                </div>
            </div>
        </form>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="workshop-map-card">
                <div id="map"></div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="workshop-list-card">
                <div class="workshop-list-head">
                    <h3>Available Workshops</h3>
                    <p>
                        @if (Model.Workshops.Any())
                        {
                            <span>@Model.Workshops.Count() result(s)</span>
                        }
                        else
                        {
                            <span>No workshops found</span>
                        }
                    </p>
                </div>

                <div class="workshop-list-body">
                    @if (Model.Workshops.Any())
                    {
                        @foreach (var workshop in Model.Workshops)
                        {
                            <div class="workshop-card"
                                 data-lat="@(workshop.Latitude?.ToString(CultureInfo.InvariantCulture))"
                                 data-lng="@(workshop.Longitude?.ToString(CultureInfo.InvariantCulture))">
                                <div class="workshop-card-top">
                                    <div>
                                        <h5 class="workshop-card-title">@workshop.Name</h5>
                                        <p class="workshop-card-city">@workshop.City</p>
                                    </div>
                                    <span class="workshop-card-dot"></span>
                                </div>

                                <p class="workshop-card-address">@workshop.Address</p>

                                @if (!string.IsNullOrWhiteSpace(workshop.PhoneNumber))
                                {
                                    <p class="workshop-card-phone">@workshop.PhoneNumber</p>
                                }

                                <a asp-controller="Appointment"
                                   asp-action="Create"
                                   asp-route-workshopId="@workshop.WorkshopId"
                                   class="btn btn-outline-primary rounded-pill px-4 workshop-choose-btn">
                                    Choose
                                </a>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="workshop-empty-state">
                            No workshops found for this city.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    <script>
        (function () {
            const map = L.map('map');
            const bulgariaCenter = [42.7339, 25.4858];

            map.setView(bulgariaCenter, 7);

            L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 19,
                attribution: '&copy; OpenStreetMap contributors'
            }).addTo(map);

            const markers = [];

        @foreach (var workshop in Model.Workshops)
        {
                if (workshop.Latitude.HasValue && workshop.Longitude.HasValue)
                {
                        <text>
                            markers.push(
                                L.circleMarker(
                                    [@workshop.Latitude.Value.ToString(CultureInfo.InvariantCulture),
                                     @workshop.Longitude.Value.ToString(CultureInfo.InvariantCulture)],
                                    {
                                        radius: 8,
                                        fillColor: "#0d6efd",
                                        color: "#ffffff",
                                        weight: 2,
                                        opacity: 1,
                                        fillOpacity: 0.95
                                    }
                                ).addTo(map).bindPopup(`
                                    <strong>@Html.Raw(JavaScriptEncoder.Default.Encode(workshop.Name))</strong><br>
                                    @Html.Raw(JavaScriptEncoder.Default.Encode(workshop.City))<br>
                                    @Html.Raw(JavaScriptEncoder.Default.Encode(workshop.Address))<br>
                                    @(string.IsNullOrWhiteSpace(workshop.PhoneNumber) ? "" : "📞 " + workshop.PhoneNumber)
                                `)
                            );
                        </text>
                }
        }

            setTimeout(function () {
                map.invalidateSize();

                if (markers.length > 0) {
                    const group = L.featureGroup(markers);
                    map.fitBounds(group.getBounds().pad(0.2));
                } else {
                    map.setView(bulgariaCenter, 7);
                }
            }, 500);

            document.querySelectorAll('.workshop-card').forEach(card => {
                card.addEventListener('click', function (e) {
                    if (e.target.tagName.toLowerCase() === 'a') return;

                    const lat = parseFloat(this.dataset.lat);
                    const lng = parseFloat(this.dataset.lng);

                    if (!isNaN(lat) && !isNaN(lng)) {
                        map.setView([lat, lng], 14);

                        markers.forEach(m => {
                            const pos = m.getLatLng();
                            if (Math.abs(pos.lat - lat) < 0.0001 && Math.abs(pos.lng - lng) < 0.0001) {
                                m.openPopup();
                            }
                        });
                    }
                });
            });
        })();
    </script>
}