@model IEnumerable<KachaowAuto.Data.Models.Part>

@{
    ViewData["Title"] = "Parts";
}

<div class="container mt-4">
    @if (User.IsInRole("Mechanic"))
    {
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="mb-1">Parts Catalog</h2>
                <p class="text-muted mb-0">Browse available parts and request what you need.</p>
            </div>

            <a asp-controller="PartRequest"
               asp-action="MyRequests"
               class="btn btn-outline-primary">
                My Requests
            </a>
        </div>

        <div class="row g-4">
            @foreach (var part in Model)
            {
                var firstImage = part.Images.OrderByDescending(i => i.PartImageId).FirstOrDefault();

                <div class="col-md-6 col-lg-4 col-xl-3">
                    <div class="card h-100 shadow-sm border-0 rounded-4">
                        <div class="p-3 text-center bg-light rounded-top-4" style="height: 230px;">
                            @if (firstImage != null)
                            {
                                <img src="@firstImage.ImageUrl"
                                     alt="@part.PartName"
                                     class="img-fluid h-100"
                                     style="object-fit: contain;" />
                            }
                            else
                            {
                                <div class="d-flex align-items-center justify-content-center h-100 text-muted">
                                    No image
                                </div>
                            }
                        </div>

                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title mb-2">@part.PartName</h5>

                            <p class="text-muted mb-2">
                                <strong>Manufacturer:</strong> @part.Manufacturer
                            </p>

                            <p class="text-muted mb-2">
                                <strong>Part Number:</strong> @part.PartNumber
                            </p>

                            <p class="text-muted mb-2">
                                <strong>Category:</strong> @(part.Category?.Name ?? "-")
                            </p>

                            <div class="mb-3">
                                @if (part.IsActive)
                                {
                                    <span class="badge bg-success">Available</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </div>

                            <div class="mt-auto">
                                <div class="fs-5 fw-bold mb-3">@part.UnitPrice.ToString("F2") лв.</div>

                                <div class="d-flex gap-2">
                                    <a asp-action="Details"
                                       asp-route-id="@part.PartId"
                                       class="btn btn-info text-white w-50">
                                        Details
                                    </a>

                                    <a asp-controller="PartRequest"
                                       asp-action="Create"
                                       asp-route-partId="@part.PartId"
                                       class="btn btn-outline-primary w-50">
                                        Request
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>Parts</h2>

            <div class="d-flex gap-2">
                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Create" class="btn btn-primary">Add New Part</a>

                    <a asp-controller="PartRequest"
                       asp-action="Index"
                       class="btn btn-dark">
                        View Requests
                    </a>
                }
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-bordered table-striped align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Image</th>
                        <th>Part Name</th>
                        <th>Manufacturer</th>
                        <th>Part Number</th>
                        <th>Category</th>
                        <th>Price</th>
                        <th>Active</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var part in Model)
                    {
                        var firstImage = part.Images.OrderByDescending(i => i.PartImageId).FirstOrDefault();

                        <tr>
                            <td>
                                @if (firstImage != null)
                                {
                                    <img src="@firstImage.ImageUrl"
                                         alt="@part.PartName"
                                         width="80"
                                         height="80"
                                         style="object-fit: cover; border-radius: 8px; border: 1px solid #ddd;" />
                                }
                                else
                                {
                                    <span>No image</span>
                                }
                            </td>
                            <td>@part.PartName</td>
                            <td>@part.Manufacturer</td>
                            <td>@part.PartNumber</td>
                            <td>@part.Category?.Name</td>
                            <td>@part.UnitPrice.ToString("F2") лв.</td>
                            <td>
                                @if (part.IsActive)
                                {
                                    <span class="badge bg-success">Yes</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">No</span>
                                }
                            </td>
                            <td class="d-flex flex-wrap gap-1">
                                <a asp-action="Details" asp-route-id="@part.PartId" class="btn btn-sm btn-info text-white">Details</a>
                                <a asp-action="Edit" asp-route-id="@part.PartId" class="btn btn-sm btn-warning">Edit</a>
                                <a asp-action="Delete" asp-route-id="@part.PartId" class="btn btn-sm btn-danger">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>