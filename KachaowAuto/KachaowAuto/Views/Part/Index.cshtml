@model IEnumerable<KachaowAuto.Data.Models.Part>

@{
    ViewData["Title"] = "Parts";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Parts</h2>
        <a asp-action="Create" class="btn btn-primary">Add New Part</a>
    </div>

    <div class="table-responsive">
        <table class="table table-bordered table-striped align-middle">
            <thead class="table-light">
                <tr>
                    <th>Image</th>
                    <th>Part Name</th>
                    <th>Manufacturer</th>
                    <th>Part Number</th>
                    <th>Category</th>
                    <th>Price</th>
                    <th>Active</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var part in Model)
                {
                    var firstImage = part.Images.OrderByDescending(i => i.PartImageId).FirstOrDefault();

                    <tr>
                        <td>
                            @if (firstImage != null)
                            {
                                <img src="@firstImage.ImageUrl"
                                     alt="@part.PartName"
                                     width="80"
                                     height="80"
                                     style="object-fit: cover; border-radius: 8px; border: 1px solid #ddd;" />
                            }
                            else
                            {
                                <span>No image</span>
                            }
                        </td>
                        <td>@part.PartName</td>
                        <td>@part.Manufacturer</td>
                        <td>@part.PartNumber</td>
                        <td>@part.Category?.Name</td>
                        <td>@part.UnitPrice.ToString("F2") лв.</td>
                        <td>
                            @if (part.IsActive)
                            {
                                <span class="badge bg-success">Yes</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">No</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@part.PartId" class="btn btn-sm btn-info text-white">Details</a>
                            <a asp-action="Edit" asp-route-id="@part.PartId" class="btn btn-sm btn-warning">Edit</a>
                            <a asp-action="Delete" asp-route-id="@part.PartId" class="btn btn-sm btn-danger">Delete</a>
                            <a asp-controller="PartImage" asp-action="Create" asp-route-partId="@part.PartId" class="btn btn-sm btn-secondary">Add Image</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>