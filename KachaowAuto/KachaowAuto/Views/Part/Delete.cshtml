@model KachaowAuto.ViewModels.Part.PartDetailsViewModel

@{
    ViewData["Title"] = "Delete Part";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-4">
            <h2 class="text-danger mb-4">Delete Part</h2>

            <div class="alert alert-warning">
                You can delete images individually or delete the entire part.
            </div>

            <p><strong>Name:</strong> @Model.PartName</p>
            <p><strong>Manufacturer:</strong> @Model.Manufacturer</p>
            <p><strong>Category:</strong> @Model.CategoryName</p>

            <hr />

            <h5>Images</h5>

            @if (Model.Images.Any())
            {
                <div class="row">
                    @foreach (var image in Model.Images)
                    {
                        <div class="col-md-3 text-center mb-3">
                            <img src="@image.ImageUrl"
                                 class="img-fluid rounded mb-2"
                                 style="height:150px; object-fit:cover;" />

                            <form asp-action="DeleteImage" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@image.PartImageId" />
                                <button class="btn btn-sm btn-outline-danger">Delete Image</button>
                            </form>
                        </div>
                    }
                </div>
            }
            else
            {
                <p>No images.</p>
            }

            <hr />

            <form asp-action="DeleteConfirmed" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.PartId" />
                <button class="btn btn-danger">Delete Part</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>