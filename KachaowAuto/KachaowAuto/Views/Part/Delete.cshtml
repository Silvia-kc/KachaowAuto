@model KachaowAuto.Data.Models.Part

@{
    ViewData["Title"] = "Delete Part";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-4">
            <h2 class="text-danger mb-4">Delete Part</h2>

            <div class="alert alert-warning">
                Here you can delete only images or delete the whole part.
            </div>

            <div class="row mb-4">
                <div class="col-md-8">
                    <p><strong>Part Name:</strong> @Model.PartName</p>
                    <p><strong>Manufacturer:</strong> @Model.Manufacturer</p>
                    <p><strong>Part Number:</strong> @Model.PartNumber</p>
                    <p><strong>Category:</strong> @Model.Category?.Name</p>
                    <p><strong>Price:</strong> @Model.UnitPrice.ToString("F2") лв.</p>
                    <p><strong>Active:</strong> @(Model.IsActive ? "Yes" : "No")</p>
                </div>
            </div>

            <h5 class="mb-3">Images</h5>

            <div class="row mb-4">
                @if (Model.Images != null && Model.Images.Any())
                {
                    @foreach (var image in Model.Images)
                    {
                        <div class="col-md-3 mb-3 text-center">
                            <img src="@image.ImageUrl"
                                 alt="@Model.PartName"
                                 class="img-fluid rounded border mb-2"
                                 style="height:180px; width:100%; object-fit:cover;"
                                 onerror="this.style.display='none'; this.nextElementSibling.style.display='block';" />

                            <div style="display:none;" class="border rounded p-4 text-muted mb-2">
                                Missing image
                            </div>

                            <form asp-controller="PartImage" asp-action="Delete" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@image.PartImageId" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    Delete Image
                                </button>
                            </form>
                        </div>
                    }
                }
                else
                {
                    <p>No images for this part.</p>
                }
            </div>

            <hr />

            <form asp-action="DeleteConfirmed" method="post">
                <input type="hidden" name="id" value="@Model.PartId" />
                <button type="submit" class="btn btn-danger">Delete Part</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>