@model KachaowAuto.Data.Models.Part

@{
    ViewData["Title"] = "Part Details";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-4">
            <h2 class="mb-4">Part Details</h2>

            <div class="row">
                <div class="col-md-8">
                    <dl class="row">
                        <dt class="col-sm-4">Part Name</dt>
                        <dd class="col-sm-8">@Model.PartName</dd>

                        <dt class="col-sm-4">Manufacturer</dt>
                        <dd class="col-sm-8">@Model.Manufacturer</dd>

                        <dt class="col-sm-4">Part Number</dt>
                        <dd class="col-sm-8">@Model.PartNumber</dd>

                        <dt class="col-sm-4">Description</dt>
                        <dd class="col-sm-8">@Model.Description</dd>

                        <dt class="col-sm-4">Category</dt>
                        <dd class="col-sm-8">@Model.Category?.Name</dd>

                        <dt class="col-sm-4">Price</dt>
                        <dd class="col-sm-8">@Model.UnitPrice.ToString("F2") лв.</dd>

                        <dt class="col-sm-4">Active</dt>
                        <dd class="col-sm-8">@(Model.IsActive ? "Yes" : "No")</dd>
                    </dl>
                </div>
            </div>

            <hr />

            <h4 class="mb-3">Images</h4>

            <div class="row">
                @if (Model.Images != null && Model.Images.Any())
                {
                    <div class="row">
                        @foreach (var image in Model.Images)
                        {
                            <div class="col-md-3 mb-3">
                                <img src="@image.ImageUrl" class="img-fluid rounded" alt="Part Image" />

                                <form asp-controller="PartImage" asp-action="Delete" method="post" class="mt-2">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@image.PartImageId" />
                                    <button type="submit" class="btn btn-danger btn-sm">
                                        Delete Image
                                    </button>
                                </form>
                            </div>
                        }
                    </div>
                }
            </div>
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                <input type="hidden" name="partId" value="@Model.PartId" />
                <div class="mb-3">
                    <input type="file" name="imageFile" class="form-control" accept="image/*" />
                </div>
                <button type="submit" class="btn btn-primary">Add Image</button>
            </form>

            <a asp-action="Index" class="btn btn-secondary mt-3">Back</a>
        </div>
    </div>
</div>