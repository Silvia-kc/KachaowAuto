@model IEnumerable<KachaowAuto.ViewModels.EngineType.EngineTypeListViewModel>

@{
    ViewData["Title"] = "Engine Types";
}

<div class="admin-page">
    <div class="admin-header">
        <div class="admin-title-wrap">
            <h1>Engine Types</h1>
            <p class="admin-subtitle">
                Manage all engine types and keep vehicle specifications organized across the system.
            </p>
        </div>

        <div class="admin-toolbar">
            <a asp-action="Create" class="btn btn-primary btn-admin">Create Engine Type</a>
        </div>
    </div>

    <div class="admin-stats">
        <div class="admin-stat-card">
            <div class="admin-stat-label">Total Engine Types</div>
            <div class="admin-stat-value accent">@Model.Count()</div>
        </div>

        <div class="admin-stat-card">
            <div class="admin-stat-label">Catalog Section</div>
            <div class="admin-stat-value">Engine Types</div>
        </div>

        <div class="admin-stat-card">
            <div class="admin-stat-label">Management Area</div>
            <div class="admin-stat-value">Admin</div>
        </div>
    </div>

    <div class="admin-panel">
        <div class="admin-panel-head">
            <div>
                <h2 class="admin-panel-title">Engine Type Directory</h2>
                <p class="admin-panel-text">Browse, edit and manage all registered engine types.</p>
            </div>
        </div>

        <div class="admin-table-wrap">
            <table class="table admin-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Models Count</th>
                        <th style="width: 220px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var e in Model)
                    {
                        <tr>
                            <td>@e.Name</td>
                            <td>@e.ModelsCount</td>
                            <td>
                                <div class="admin-actions">
                                    <a asp-action="Edit" asp-route-id="@e.EngineTypeId" class="btn btn-warning btn-admin-sm">Edit</a>
                                    <a asp-action="Delete" asp-route-id="@e.EngineTypeId" class="btn btn-danger btn-admin-sm">Delete</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>